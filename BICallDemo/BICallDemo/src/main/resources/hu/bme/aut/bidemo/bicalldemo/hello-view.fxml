<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="hu.bme.aut.bidemo.bicalldemo.HelloController"
            prefWidth="800.0" prefHeight="500.0">
    <children>
        <VBox spacing="10.0" AnchorPane.topAnchor="10.0" AnchorPane.leftAnchor="10.0"
              AnchorPane.rightAnchor="10.0" AnchorPane.bottomAnchor="10.0">
            <HBox spacing="10.0">
                <Button fx:id="btnQueryAll" text="Query All" onAction="#onQueryAll"/>
            </HBox>
            <TextArea fx:id="txtOutput" wrapText="false" prefRowCount="20"
                      promptText="Logs and query results will appear here..."/>
        </VBox>
    </children>
</AnchorPane>